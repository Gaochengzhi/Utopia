{
    "name": "web-blog",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "export PORT=8888 && next start",
        "lint": "next lint",
        "analyze": "cross-env ANALYZE=true next build",
        "analyze:server": "cross-env BUNDLE_ANALYZE=server next build",
        "analyze:browser": "cross-env BUNDLE_ANALYZE=browser next build",
        "upload": "./upload.sh",
        "upload:articles": "./upload.sh --articles-only",
        "upload:images": "./upload.sh --images-only",
        "upload:dry": "./upload.sh --dry-run",
        "deploy": "./deploy.sh",
        "deploy:code": "./deploy.sh --code-only",
        "deploy:content": "./deploy.sh --content-only",
        "deploy:full": "./deploy.sh --full",
        "build:content-index": "node scripts/build-content-index.mjs",
        "build:content-index:incremental": "node scripts/build-content-index.mjs --incremental",
        "cf:build": "npx opennextjs-cloudflare build && rm -rf .open-next/assets/.pic .open-next/assets/photography",
        "cf:deploy": "npm run cf:build && npx wrangler deploy",
        "sync-r2": "node scripts/sync-r2.mjs",
        "sync-r2:dry": "node scripts/sync-r2.mjs --dry-run",
        "d1:seed": "bash scripts/d1-seed-remote.sh",
        "d1:seed:dry": "bash scripts/d1-seed-remote.sh --dry-run"
    },
    "dependencies": {
        "@next/bundle-analyzer": "^15.5.14",
        "cross-env": "^7.0.3",
        "github-markdown-css": "^5.1.0",
        "gray-matter": "^4.0.3",
        "js-cookie": "^3.0.1",
        "next": "^15.5.14",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "react-markdown": "^8.0.3",
        "react-photo-view": "^1.2.2",
        "react-syntax-highlighter": "^15.5.0",
        "rehype-katex": "^6.0.2",
        "rehype-raw": "^6.1.1",
        "remark-gfm": "^3.0.1",
        "remark-math": "^5.1.1"
    },
    "devDependencies": {
        "@aws-sdk/client-s3": "^3.700.0",
        "@opennextjs/cloudflare": "^1.18.0",
        "autoprefixer": "^10.4.8",
        "eslint": "8.57.1",
        "eslint-config-next": "^15.5.14",
        "p-limit": "^7.3.0",
        "postcss": "^8.4.16",
        "sharp": "^0.34.5",
        "tailwindcss": "^3.1.8",
        "wrangler": "^4.78.0"
    }
}
