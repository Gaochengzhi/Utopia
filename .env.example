# Cloudflare D1
D1_DATABASE_NAME=utopia-db
D1_DATABASE_ID=replace-with-your-d1-database-id

# Cloudflare R2
R2_ACCOUNT_ID=replace-with-your-r2-account-id
R2_ACCESS_KEY_ID=replace-with-your-r2-access-key-id
R2_SECRET_ACCESS_KEY=replace-with-your-r2-secret-access-key
R2_BUCKET_NAME=utopia-images
NEXT_PUBLIC_R2_CDN_URL=https://cdn.gaochengzhi.com
# Optional: set true to allow localhost fallback when CDN image fails
NEXT_PUBLIC_ENABLE_LOCAL_ORIGIN_FALLBACK=false

# App auth
DIARY_PASSWORD=replace-with-your-diary-password
HMAC_SECRET=replace-with-your-hmac-secret
